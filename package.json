{
  "name": "traders",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "predev": "true",
    "dev:web": "vite",
    "dev:electron": "wait-on http://127.0.0.1:5173 -t 60000 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:electron\"",
    "build": "vite build",
    "start": "electron .",
    "launch": "electron ."
  },
  "dependencies": {
    "lucide-react": "^0.577.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.1.5",
    "typescript": "^5.7.2",
    "vite": "^6.1.0",
    "wait-on": "^8.0.3"
  }
}
